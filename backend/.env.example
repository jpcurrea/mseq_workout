# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ===== App Configuration =====
SECRET_KEY=your-super-secret-key-change-this-in-production
FRONTEND_URL=http://localhost:55905

# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ===== Google OAuth (Required) =====
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ===== GitHub OAuth (Optional) =====
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===== Database =====
# SQLite (default for development)
DATABASE_URL=sqlite:///data/workout_app.db

# PostgreSQL (for production - optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/workout_db

# ===== Deployment URLs =====
# Update these when deploying to production
# Local development:
#   FRONTEND_URL=http://localhost:55905
#   Backend runs on: http://localhost:8000
#
# Production (update redirect URIs in OAuth console too):
#   FRONTEND_URL=https://your-app.netlify.app
#   Backend: https://your-backend.onrender.com
