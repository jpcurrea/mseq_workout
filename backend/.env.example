# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ===== App Configuration =====
SECRET_KEY=your-super-secret-key-change-this-in-production
FRONTEND_URL=http://localhost:55905

# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ===== Google OAuth (Required) =====
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ===== GitHub OAuth (Optional) =====
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===== Database =====
# SQLite (default for development)
DATABASE_URL=sqlite:///data/workout_app.db

# PostgreSQL (for production - optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/workout_db

# ===== Deployment URLs =====
# Update these when deploying to production
# Local development:
#   FRONTEND_URL=http://localhost:55905
#   Backend runs on: http://localhost:8000
#
# Production (update redirect URIs in OAuth console too):
#   FRONTEND_URL=https://your-app.netlify.app
#   Backend: https://your-backend.onrender.com

# ===== LLM Agent (Planning/Analytics Chat) =====
# Token-based / pay-per-use setup (Option A). The backend calls any
# OpenAI-compatible /chat/completions endpoint, so you only set 3 vars.
#
# Privacy notes (paid APIs, NOT the consumer chat apps):
#   - OpenAI API does NOT train on API data by default; default 30-day
#     retention, and Zero-Data-Retention (ZDR) is available on request.
#   - For a contractual + regional boundary at the same per-token pricing,
#     point LLM_API_BASE_URL at Azure OpenAI / AWS Bedrock / Google Vertex.
#   - "Never leaves my server" requires self-hosting, not a token API.
#
# These LLM_* values are the SERVER default (shared key). Individual users may
# override them with their own provider key/base_url/model via the in-app
# "AI provider settings" dialog; those keys are stored encrypted (Fernet,
# derived from SECRET_KEY) and never count toward LLM_SPEND_CAP_USD.
# IMPORTANT: set a stable SECRET_KEY in production — if it changes, stored
# per-user keys can no longer be decrypted and must be re-entered.
#
# Provide at least one API key option below.
# If you use OpenAI directly, OPENAI_API_KEY is enough.
LLM_API_KEY=
OPENAI_API_KEY=

# OpenAI-compatible chat completions endpoint base URL.
# Examples:
#   OpenAI: https://api.openai.com/v1
#   Local proxy/Ollama-compatible gateway: http://localhost:11434/v1
LLM_API_BASE_URL=https://api.openai.com/v1

# If LLM_API_BASE_URL points to localhost/127.0.0.1, API key is optional.
# For non-local endpoints, provide LLM_API_KEY or OPENAI_API_KEY.

# Model identifier used by /agent/chat
LLM_MODEL=gpt-4o-mini

# Optional request timeout (seconds)
LLM_TIMEOUT_SECONDS=120

# Hard cumulative spending cap in USD. Once total estimated spend reaches this,
# /agent/chat returns HTTP 429 until you raise the value. Default: 10.
LLM_SPEND_CAP_USD=10

# File attachments: the agent reads attached PDFs/text/images by extracting text
# first, then falling back to sending page images for scanned PDFs. The vision
# fallback (and image attachments) require a vision-capable LLM_MODEL such as
# gpt-4o-mini, gpt-4o, or gpt-4.1*. Images add tokens, which count toward
# LLM_SPEND_CAP_USD. PDF support requires the pymupdf package (in requirements).
